---
import Volkswagen from "./logos/Volkswagen.astro";
import Sanofi from "./logos/Sanofi.astro";
import Treemetrics from "./logos/Treemetrics.astro";
import Dgfip from "./logos/Dgfip.astro";
import EuropeanSpaceAgency from "./logos/EuropeanSpaceAgency.astro";
import B4bet from "./logos/B4bet.astro";
import DigitalButterfly from "./logos/DigitalButterfly.astro";
import Abcdis from "./logos/Abcdis.astro";
import Gymix from "./logos/Gymix.astro";

const logos = [
  Volkswagen,
  Sanofi,
  Treemetrics,
  Dgfip,
  EuropeanSpaceAgency,
  B4bet,
  DigitalButterfly,
  Abcdis,
  Gymix,
];
---

<section
  class="py-16 md:py-24 px-6 border-b border-gray-100 dark:border-gray-800/50"
>
  <div class="max-w-6xl mx-auto text-center">
    <p
      class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-10 md:mb-16 reveal"
    >
      Previously worked with
    </p>

    <div id="logo-carousel" class="grid grid-cols-1 items-center min-h-[100px]">
      {
        logos.map((Logo, index) => (
          <div
            class="reveal flex items-center justify-center w-full h-full transition-all duration-300"
            style={`transition-delay: ${(index + 1) * 100}ms;`}
          >
            <Logo />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const initLogoCarousel = () => {
    const container = document.getElementById("logo-carousel");
    if (!container) return;

    if (!container.dataset.carouselInitialized) {
      const logos = Array.from(container.children);
      logos.forEach((l) => container.removeChild(l));

      const batchSize = 3;
      const totalBatches = Math.ceil(logos.length / batchSize);

      for (let i = 0; i < totalBatches; i++) {
        const slide = document.createElement("div");
        slide.className =
          "col-start-1 row-start-1 grid grid-cols-3 place-items-center gap-4 md:gap-12 w-full  md:max-w-3xl mx-auto transition-all duration-1000 ease-in-out";

        if (i === 0) {
          slide.style.opacity = "1";
          slide.style.filter = "blur(0px)";
          slide.style.transform = "translateY(0px)";
          slide.style.pointerEvents = "auto";
          slide.style.zIndex = "1";
        } else {
          slide.style.opacity = "0";
          slide.style.filter = "blur(10px)";
          slide.style.transform = "translateY(20px)";
          slide.style.pointerEvents = "none";
          slide.style.zIndex = "0";
        }

        const start = i * batchSize;
        const end = start + batchSize;
        const batchLogos = logos.slice(start, end);

        batchLogos.forEach((logo) => {
          logo.classList.remove("reveal");
          logo.classList.remove("hidden", "lg:flex");
          slide.appendChild(logo);
        });

        container.appendChild(slide);
      }
      container.dataset.carouselInitialized = "true";
    }

    const slides = Array.from(container.children);
    if (slides.length <= 1) return;

    let currentBatch = 0;

    // Type definition for window object to avoid TS errors in strict mode if applicable
    // @ts-ignore
    if (window.logoCarouselInterval) clearInterval(window.logoCarouselInterval);

    // @ts-ignore
    window.logoCarouselInterval = setInterval(() => {
      const oldSlide = slides[currentBatch];
      currentBatch = (currentBatch + 1) % slides.length;
      const newSlide = slides[currentBatch];

      // Old slide exits moving up
      oldSlide.style.opacity = "0";
      oldSlide.style.filter = "blur(10px)";
      oldSlide.style.transform = "translateY(-20px)";
      oldSlide.style.pointerEvents = "none";
      oldSlide.style.zIndex = "0";

      // Prepare new slide instantly at the bottom
      newSlide.style.transition = "none";
      newSlide.style.transform = "translateY(20px)";
      void newSlide.offsetWidth; // force reflow
      newSlide.style.transition = "all 1000ms ease-in-out";

      // New slide enters moving up to center
      newSlide.style.opacity = "1";
      newSlide.style.filter = "blur(0px)";
      newSlide.style.transform = "translateY(0px)";
      newSlide.style.pointerEvents = "auto";
      newSlide.style.zIndex = "1";
    }, 4000);
  };

  initLogoCarousel();

  document.addEventListener("astro:page-load", () => {
    initLogoCarousel();
  });
</script>
