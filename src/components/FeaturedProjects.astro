---
---
      <!-- Selected Work Section -->
      <section
        class="py-32 px-6 max-w-6xl mx-auto border-t border-gray-100 dark:border-gray-800/50"
      >
        <div
          class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 reveal"
        >
          <div>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
              Selected Work
            </h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400 max-w-xl text-lg">
              A showcase of recent projects, experiments, and open-source
              contributions.
            </p>
          </div>
          <a
            href="/work"
            class="inline-flex items-center gap-2 text-accent font-medium hover:gap-3 transition-all"
          >
            See all projects <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            [1, 2, 3, 4].map((item, i) => (
              <div
                class="reveal group relative overflow-hidden rounded-3xl bg-gray-100 dark:bg-slate-800 aspect-[4/3]"
                style={`transition-delay: ${(i % 2) * 150}ms`}
              >
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500 z-10" />

                <div class="absolute inset-0 bg-slate-200 dark:bg-slate-700 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out" />

                <div class="absolute bottom-0 left-0 p-8 z-20 w-full translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                  <p class="text-accent text-sm font-medium mb-2">
                    Web Application
                  </p>
                  <h3 class="text-2xl font-bold text-white mb-2">
                    Project {item}
                  </h3>
                  <p class="text-gray-300 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                    A brief description of this amazing project and the
                    technologies used to build it.
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </section>