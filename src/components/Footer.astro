---
const today = new Date();
---

<footer
  class="mt-16 bg-white/50 dark:bg-slate-950/50"
>
  <div class="max-w-7xl px-4 md:px-8 py-12 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      <!-- Left: Brand & Tagline -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 group">
          <span
            class="font-bold text-xl tracking-tight text-slate-900 dark:text-white group-hover:opacity-75 transition-opacity"
            >BOUZAHAR Anis</span
          >
        </a>
        <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          Digital craftsman building sleek, modern, and highly performant web
          applications.
        </p>
      </div>

      <!-- Center: Quick Links -->
      <div class="grid grid-cols-2 gap-4 text-sm md:mx-auto">
        <div class="space-y-3">
          <h3 class="font-semibold text-slate-900 dark:text-white">Pages</h3>
          <ul class="space-y-2 text-gray-600 dark:text-gray-400">
            <li>
              <a
                href="/"
                class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >Home</a
              >
            </li>
            <li>
              <a
                href="/about"
                class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >About</a
              >
            </li>
            <li>
              <a
                href="/blog"
                class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >Blog</a
              >
            </li>
          </ul>
        </div>
        <div class="space-y-3">
          <h3 class="font-semibold text-slate-900 dark:text-white">Legal</h3>
          <ul class="space-y-2 text-gray-600 dark:text-gray-400">
            <li>
              <a
                href="/privacy"
                class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >Privacy Policy</a
              >
            </li>
            <li>
              <a
                href="/terms"
                class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >Terms of Service</a
              >
            </li>
            <li>
              <a
                href={import.meta.env.PUBLIC_STATUS_PAGE_URL}
                target="_blank"
                class="hover:text-slate-900 dark:hover:text-white transition-colors inline-flex items-center gap-2"
                id="status-link"
                >Services Status
                <span class="relative flex h-2 w-2" id="status-dot">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-slate-400 opacity-75 status-ping"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-slate-500 status-core"></span>
                </span>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Right: Socials -->
      <div class="space-y-4 md:text-right">
        <h3 class="font-semibold text-slate-900 dark:text-white">Connect</h3>
        <div class="flex items-center md:justify-end gap-4">
          <a
            href="#"
            target="_blank"
            class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors"
          >
            <span class="sr-only">Go to Anis's LinkedIn</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
          <a
            href="https://github.com/anisbouzahar"
            target="_blank"
            class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors"
          >
            <span class="sr-only">Go to Anis's GitHub</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400"
    >
      <p>&copy; {today.getFullYear()} BOUZAHAR Anis. All rights reserved.</p>
      <p>
        Crafted in Morocco with
        <span class="inline-flex items-center whitespace-nowrap">
          <svg
            width="12px"
            height="12px"
            viewBox="0 0 15 15"
            version="1.1"
            id="heart"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            class="inline-block align-middle mx-1 dark:text-white text-slate-900"
          >
            <path
              fill="currentColor"
              d="M13.91,6.75c-1.17,2.25-4.3,5.31-6.07,6.94c-0.1903,0.1718-0.4797,0.1718-0.67,0C5.39,12.06,2.26,9,1.09,6.75
C-1.48,1.8,5-1.5,7.5,3.45C10-1.5,16.48,1.8,13.91,6.75z"
            ></path>
          </svg>.
        </span>
      </p>
    </div>
  </div>
</footer>

<script>
  async function updateStatus() {
    try {
      const apiUrl = import.meta.env.PUBLIC_STATUS_API_URL;
      const response = await fetch(apiUrl);
      const text = await response.text();
      
      const ping = document.querySelector('#status-dot .status-ping');
      const core = document.querySelector('#status-dot .status-core');
      
      if (ping && core) {
        // Reset classes
        ping.className = 'animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 status-ping';
        core.className = 'relative inline-flex rounded-full h-2 w-2 status-core';
        
        if (text.includes('>Up<')) {
          ping.classList.add('bg-emerald-400');
          core.classList.add('bg-emerald-500');
        } else if (text.includes('>Down<')) {
          ping.classList.add('bg-red-400');
          core.classList.add('bg-red-500');
        } else {
          ping.classList.add('bg-yellow-400');
          core.classList.add('bg-yellow-500');
        }
      }
    } catch (error) {
      console.error('Failed to fetch status:', error);
    }
  }

  // Run on initial load
  updateStatus();
  
  // Optionally update every 60 seconds
  setInterval(updateStatus, 60000);
</script>
