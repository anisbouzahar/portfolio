<!-- Call to Action -->
<section
  id="cta-inner"
  class="w-full flex flex-col items-center justify-center px-6 py-24 text-center bg-accent/5 origin-top will-change-transform transition-colors duration-300"
>
  <div class="max-w-5xl mx-auto py-12">
    <h2
      class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8 text-slate-900 dark:text-white"
    >
      Let's build something amazing together.
    </h2>
    <p
      class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto"
    >
      Have a project in mind or just want to chat? I'm always open to discussing
      new opportunities.
    </p>
    <a
      href="/contact"
      class="h-16 px-12 inline-flex items-center justify-center rounded-full bg-accent text-white font-bold hover:bg-accent-hover hover:scale-105 transition-all duration-300 shadow-xl shadow-accent/20 text-xl"
    >
      Say Hello
    </a>
  </div>
</section>
