---
---
      <section
        class="min-h-screen flex items-center justify-center pt-20 px-6 relative overflow-hidden"
        id="hero"
      >
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-accent/10 via-white to-white dark:from-accent/10 dark:via-slate-950 dark:to-slate-950 -z-20"
        >
        </div>
        <canvas
          id="hero-canvas"
          class="absolute inset-0 w-full h-full -z-10 opacity-70"></canvas>

        <div
          class="absolute bottom-0 inset-x-0 h-16 bg-linear-to-t from-white dark:from-slate-950 to-transparent pointer-events-none z-0"
        >
        </div>

        <div class="max-w-4xl mx-auto text-center space-y-8 relative z-10">
          <h1
            class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter leading-[1.1] animate-blur-in-up"
          >
            Digital craftsman <br class="hidden md:block" />
            <span
              id="hero-gradient-text"
              class="text-transparent bg-clip-text transition-all duration-75 ease-out"
              style="background-image: radial-gradient(circle at 50% 50%, var(--accent), #a855f7, var(--accent)); background-size: 200% 200%;"
              >building sleek</span
            > experiences.
          </h1>

          <p
            class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed animate-blur-in-up"
            style="animation-delay: 150ms;"
          >
            I'm a software engineer. I focus on building fast, highly
            interactive web applications with a strong attention to detail.
          </p>

          <div
            class="flex flex-wrap items-center justify-center gap-4 pt-4 animate-blur-in-up"
            style="animation-delay: 300ms;"
          >
            <a
              href="/work"
              class="h-12 px-8 inline-flex items-center justify-center rounded-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-medium hover:bg-slate-800 dark:hover:bg-gray-100 transition-colors duration-300"
            >
              View my work
            </a>
            <a
              href="/contact"
              class="h-12 px-8 inline-flex items-center justify-center rounded-full bg-white/40 dark:bg-slate-900/40 backdrop-blur-md border border-gray-200/50 dark:border-gray-800/50 text-slate-900 dark:text-white font-medium hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors duration-300"
            >
              Get in touch
            </a>
          </div>
        </div>
      </section>

<script>
import { Renderer, Camera, Transform, Program, Mesh, Geometry } from "ogl";

      // --- Cursor Reactive Gradient ---
      const gradientText = document.getElementById("hero-gradient-text");
      if (gradientText) {
        document.addEventListener("mousemove", (e) => {
          // Calculate cursor position relative to the text element
          const rect = gradientText.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;

          // Soft, glowing neon purple instead of harsh white
          gradientText.style.backgroundImage = `radial-gradient(150px circle at ${x}px ${y}px, #e879f9 0%, var(--accent) 50%, var(--accent) 100%)`;
        });
      }

      // --- OGL Elegant Centerpiece ---
      const initCanvas = () => {
        const canvas = document.getElementById("hero-canvas");
        if (!canvas) return;

        // Clear previous instances for hot reloads / Astro view transitions
        if (window.heroCustomRender) {
          cancelAnimationFrame(window.heroCustomRender);
        }

        let width = window.innerWidth;
        let height = window.innerHeight;

        const isDark = document.documentElement.classList.contains("dark");
        const parseHex = (hex) => [((hex >> 16) & 255) / 255, ((hex >> 8) & 255) / 255, (hex & 255) / 255];
        
        const darkBg = parseHex(0x020617);
        const lightBg = parseHex(0xffffff);
        const darkWire = parseHex(0xc084fc);
        const lightWire = parseHex(0x000000);

        const currentBg = isDark ? darkBg : lightBg;

        // Renderer
        const renderer = new Renderer({ canvas, antialias: true, dpr: 1 }); // Hardcoded DPR to 1 to save GPU
        const gl = renderer.gl;
        gl.clearColor(currentBg[0], currentBg[1], currentBg[2], 1);
        renderer.setSize(width, height);
        window.heroRenderer = renderer;

        const scene = new Transform();

        // Camera
        const camera = new Camera(gl, { fov: 60, aspect: width / height });
        camera.position.set(0, 5, 20);
        camera.rotation.x = -0.2;

        // --- WIREFRAME TERRAIN ---
        const w = 100;
        const h = 100;
        const segmentsX = 40;
        const segmentsY = 40;
        
        const positions = new Float32Array((segmentsX + 1) * (segmentsY + 1) * 3);
        const indices = [];

        for (let y = 0; y <= segmentsY; y++) {
          for (let x = 0; x <= segmentsX; x++) {
            const i = y * (segmentsX + 1) + x;
            positions[i * 3] = (x / segmentsX - 0.5) * w;
            positions[i * 3 + 1] = (y / segmentsY - 0.5) * h;
            positions[i * 3 + 2] = 0;
            
            if (x < segmentsX) indices.push(i, i + 1);
            if (y < segmentsY) indices.push(i, i + segmentsX + 1);
          }
        }

        const geometry = new Geometry(gl, {
            position: { size: 3, data: positions },
            index: { data: new Uint16Array(indices) }
        });

        // Vertex Shader: Math is now on the GPU
        const vertex = `
            attribute vec3 position;
            uniform mat4 modelViewMatrix;
            uniform mat4 projectionMatrix;
            uniform float uTime;
            
            void main() {
                vec3 pos = position;
                // Apply seamless wave displacement
                pos.z = sin(pos.x * 0.15 + uTime * 0.5) * 1.5 + cos(pos.y * 0.15 + uTime * 2.0) * 1.5;
                gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
            }
        `;

        // Fragment Shader: Handles Color and Fog
        const fragment = `
            precision highp float;
            uniform vec3 uColor;
            uniform vec3 uFogColor;
            uniform float uFogDensity;
            
            void main() {
                // Fog calculation
                float depth = gl_FragCoord.z / gl_FragCoord.w;
                float fogFactor = exp2(-uFogDensity * uFogDensity * depth * depth * 1.442695);
                fogFactor = clamp(fogFactor, 0.0, 1.0);
                
                vec4 color = vec4(uColor, 0.25);
                vec4 fogColor = vec4(uFogColor, 1.0);
                
                gl_FragColor = mix(fogColor, color, fogFactor);
            }
        `;

        const program = new Program(gl, {
            vertex,
            fragment,
            uniforms: {
                uTime: { value: 0 },
                uColor: { value: isDark ? darkWire : lightWire },
                uFogColor: { value: currentBg },
                uFogDensity: { value: 0.035 }
            },
            transparent: true
        });

        const terrain = new Mesh(gl, { geometry, program, mode: gl.LINES });
        terrain.rotation.x = -Math.PI / 2;
        terrain.position.y = -5;
        terrain.setParent(scene);

        // --- PARALLAX MOUSE TRACKING ---
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;
        const windowHalfX = width / 2;
        const windowHalfY = height / 2;

        const onDocumentMouseMove = (event) => {
          mouseX = (event.clientX - windowHalfX) * 0.05;
          mouseY = (event.clientY - windowHalfY) * 0.05;
        };
        document.addEventListener("mousemove", onDocumentMouseMove);

        let isVisible = true;
        let isAnimating = false;
        const heroSection = document.getElementById("hero");

        // --- ANIMATION LOOP ---
        const animate = (t) => {
          if (!isVisible) {
            isAnimating = false;
            return;
          }
          isAnimating = true;
          window.heroCustomRender = requestAnimationFrame(animate);
          
          program.uniforms.uTime.value = t * 0.001;

          // Smooth mouse parallax
          targetX = mouseX * 0.2;
          targetY = mouseY * 0.2;
          camera.position.x += (targetX - camera.position.x) * 0.05;
          camera.position.y += (5 - targetY - camera.position.y) * 0.05;
          camera.lookAt([0, -2, 0]);

          renderer.render({ scene, camera });
        };

        if (heroSection) {
          const visibilityObserver = new IntersectionObserver((entries) => {
            isVisible = entries[0].isIntersecting;
            if (isVisible && !isAnimating) {
              requestAnimationFrame(animate);
            }
          });
          visibilityObserver.observe(heroSection);
        } else {
          requestAnimationFrame(animate);
        }

        // --- DYNAMIC THEME UPDATES ---
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === "class") {
              const currentlyDark = document.documentElement.classList.contains("dark");
              const bg = currentlyDark ? darkBg : lightBg;
              program.uniforms.uColor.value = currentlyDark ? darkWire : lightWire;
              program.uniforms.uFogColor.value = bg;
              gl.clearColor(bg[0], bg[1], bg[2], 1);
            }
          });
        });
        observer.observe(document.documentElement, { attributes: true });

        document.addEventListener(
          "astro:before-swap",
          () => observer.disconnect(),
          { once: true },
        );

        // Handle resize
        window.addEventListener("resize", () => {
          width = window.innerWidth;
          height = window.innerHeight;
          camera.perspective({ aspect: width / height });
          renderer.setSize(width, height);
        });
      };

  // Initialize using idle callback to avoid blocking critical rendering path
  const triggerInit = () => {
    if (window.requestIdleCallback) {
      window.requestIdleCallback(() => initCanvas());
    } else {
      setTimeout(initCanvas, 500);
    }
  };

  if (document.readyState === 'complete') {
    triggerInit();
  } else {
    window.addEventListener('load', triggerInit);
  }

  document.addEventListener("astro:page-load", () => {
    if (document.readyState === 'complete') {
      initCanvas();
    }
  });
</script>
