---
import logo from "../assets/logo.svg";
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;
const isCurrent = (path: string) => {
  if (path === '/' && pathname === '/') return true;
  if (path !== '/' && pathname.startsWith(path)) return true;
  return false;
};

const getLinkClass = (path: string) => {
  const base = "nav-link inline-block px-5 py-2 text-base rounded-full transition-colors duration-200";
  const active = "text-slate-900 dark:text-white font-semibold";
  const inactive = "text-slate-700 dark:text-slate-200 font-medium hover:text-slate-900 dark:hover:text-white";
  return `${base} ${isCurrent(path) ? active : inactive}`;
};

const getMobileLinkClass = (path: string) => {
  const base = "text-3xl transition-colors";
  const active = "text-accent dark:text-accent font-bold";
  const inactive = "text-slate-800 dark:text-slate-200 font-medium hover:text-slate-900 dark:hover:text-white";
  return `${base} ${isCurrent(path) ? active : inactive}`;
};
---

<div class="w-full fixed h-40 top-0 z-[21] pointer-events-none">
  <div
    class="absolute inset-0 pointer-events-none"
    style="backdrop-filter: blur(1px); -webkit-backdrop-filter: blur(1px); mask-image: linear-gradient(to bottom, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); mask-image: linear-gradient(to bottom, black 45%, transparent 85%); -webkit-mask-image: linear-gradient(to bottom, black 45%, transparent 85%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); mask-image: linear-gradient(to bottom, black 30%, transparent 70%); -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 70%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); mask-image: linear-gradient(to bottom, black 15%, transparent 55%); -webkit-mask-image: linear-gradient(to bottom, black 15%, transparent 55%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); mask-image: linear-gradient(to bottom, black 0%, transparent 40%); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 40%);"
  >
  </div>
</div>

<header class="fixed top-0 left-0 w-full z-50 pointer-events-none">
  <div
    class="container flex justify-between items-center px-6 py-6 lg:px-8 mx-auto"
  >
    <div class="pointer-events-auto">
      <a href="/" class="flex items-center gap-2 group">
        <img
          src={logo.src}
          alt="Brand Logo"
          height="40px"
          width="40px"
          class="w-8 h-auto transition-transform dark:invert"
        />
      </a>
    </div>

    <!-- Center/Right wrapper -->
    <div class="flex items-center gap-4 lg:gap-8 pointer-events-auto">
      <!-- Navigation with Sliding Magic Pill effect -->
      <nav class="hidden lg:block">
        <!-- Floating glass container for the nav -->
        <ul id="nav-menu" class="relative flex items-center gap-1 px-2 py-1.5">
          <!-- The sliding background pill -->
          <li
            id="nav-pill"
            class="absolute left-0 top-0 bg-black/5 dark:bg-white/10 rounded-full transition-all duration-300 ease-out opacity-0 pointer-events-none z-0"
            role="presentation"
            aria-hidden="true"
          >
          </li>

          <li class="relative z-10">
            <a href="/work" class={getLinkClass('/work')}>Work</a>
          </li>
          <li class="relative z-10">
            <a href="/services" class={getLinkClass('/services')}>Services</a>
          </li>
          <li class="relative z-10">
            <a href="/blog" class={getLinkClass('/blog')}>Blog</a>
          </li>
          <li class="relative z-10">
            <a href="/about" class={getLinkClass('/about')}>About</a>
          </li>
        </ul>
      </nav>

      <div class="flex items-center gap-3">
        <div
          class="bg-white/40 dark:bg-slate-900/40 backdrop-blur-md rounded-full border border-gray-200/50 dark:border-gray-800/50 hover:bg-white/60 dark:hover:bg-slate-900/60 transition-colors duration-300 shadow-xs p-1"
        >
          <ThemeToggle />
        </div>

        <a
          href="/contact"
          class="hidden sm:flex items-center justify-center h-12 px-8 rounded-full bg-accent text-white dark:text-slate-900 font-medium hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/10"
        >
          Start project
        </a>

        <button
          id="mobile-menu-btn"
          class="flex lg:hidden flex-col justify-center items-center gap-1.5 w-12 h-12 bg-white/40 dark:bg-slate-900/40 backdrop-blur-md rounded-full shadow-sm border border-gray-200/50 dark:border-gray-800/50 pointer-events-auto"
          aria-label="Toggle mobile menu"
        >
          <div id="line-1" class="w-5 h-0.5 bg-slate-900 dark:bg-white rounded transition-transform duration-300 origin-center"></div>
          <div id="line-2" class="w-5 h-0.5 bg-slate-900 dark:bg-white rounded transition-opacity duration-300"></div>
          <div id="line-3" class="w-5 h-0.5 bg-slate-900 dark:bg-white rounded transition-transform duration-300 origin-center"></div>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[40] bg-white/95 dark:bg-slate-950/95 backdrop-blur-xl translate-x-full transition-transform duration-500 ease-in-out flex flex-col justify-center items-center pointer-events-auto lg:hidden">
  <nav class="flex flex-col items-center gap-8">
    <a href="/work" class={getMobileLinkClass('/work')}>Work</a>
    <a href="/services" class={getMobileLinkClass('/services')}>Services</a>
    <a href="/blog" class={getMobileLinkClass('/blog')}>Blog</a>
    <a href="/about" class={getMobileLinkClass('/about')}>About</a>
    <a href="/contact" class="mt-4 px-8 py-3 rounded-full bg-accent text-white dark:text-slate-900 text-xl font-medium hover:bg-accent-hover transition-colors shadow-lg shadow-accent/20">Start project</a>
  </nav>
</div>

<script>
  function initNavPill() {
    const navMenu = document.getElementById("nav-menu");
    const navPill = document.getElementById("nav-pill");
    const navLinks = document.querySelectorAll(".nav-link");

    if (!navMenu || !navPill) return;

    navLinks.forEach((link) => {
      link.addEventListener("mouseenter", (e) => {
        const target = e.currentTarget as HTMLElement;
        const menuRect = navMenu.getBoundingClientRect();
        const linkRect = target.getBoundingClientRect();

        const left = linkRect.left - menuRect.left;
        const top = linkRect.top - menuRect.top;

        // If the pill is currently hidden, snap it to position without animating
        if (navPill.style.opacity === "0" || navPill.style.opacity === "") {
          navPill.style.transition = "none";
          navPill.style.width = `${linkRect.width}px`;
          navPill.style.height = `${linkRect.height}px`;
          navPill.style.transform = `translate(${left}px, ${top}px)`;

          // Force reflow to apply instantaneous position
          navPill.offsetHeight;

          // Re-enable CSS transitions and fade in
          navPill.style.transition = "";
          navPill.style.opacity = "1";
        } else {
          // If already visible, smoothly animate position and size
          navPill.style.width = `${linkRect.width}px`;
          navPill.style.height = `${linkRect.height}px`;
          navPill.style.transform = `translate(${left}px, ${top}px)`;
        }
      });
    });

    navMenu.addEventListener("mouseleave", () => {
      navPill.style.opacity = "0";
    });
  }

  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("line-1");
    const line2 = document.getElementById("line-2");
    const line3 = document.getElementById("line-3");
    let isOpen = false;

    if (!btn || !menu || !line1 || !line2 || !line3) return;

    // Reset state in case of view transitions
    menu.classList.add("translate-x-full");
    menu.classList.remove("translate-x-0");
    line1.style.transform = "none";
    line2.style.opacity = "1";
    line3.style.transform = "none";
    document.body.style.overflow = "";

    const toggleMenu = () => {
      isOpen = !isOpen;
      if (isOpen) {
        menu.classList.remove("translate-x-full");
        menu.classList.add("translate-x-0");
        line1.style.transform = "translateY(8px) rotate(45deg)";
        line2.style.opacity = "0";
        line3.style.transform = "translateY(-8px) rotate(-45deg)";
        document.body.style.overflow = "hidden";
      } else {
        menu.classList.remove("translate-x-0");
        menu.classList.add("translate-x-full");
        line1.style.transform = "none";
        line2.style.opacity = "1";
        line3.style.transform = "none";
        document.body.style.overflow = "";
      }
    };

    btn.onclick = toggleMenu;

    menu.querySelectorAll("a").forEach((link) => {
      link.onclick = () => {
        if (isOpen) toggleMenu();
      };
    });
  }

  // Initialize on page load
  initNavPill();
  initMobileMenu();

  // Re-initialize after view transitions (if Astro View Transitions are used)
  document.addEventListener("astro:page-load", () => {
    initNavPill();
    initMobileMenu();
  });
</script>
