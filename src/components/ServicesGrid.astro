---

---

<!-- Services / Skills Section -->
<section
  class="py-32 px-6 max-w-6xl mx-auto border-t border-gray-100 dark:border-gray-800/50"
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Text Content -->
    <div class="space-y-8 reveal">
      <h2
        class="text-3xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white leading-tight"
      >
        A balanced approach to <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-purple-600"
          >Full-Stack Development</span
        >
      </h2>

      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        I am a versatile software engineer with a strong focus on the JavaScript
        and TypeScript ecosystem. By blending robust technical architecture with
        strong soft skills, I build scalable applications using modern tools
        like React, Vue, and Nuxt.
      </p>

      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        My philosophy is that writing clean, performant code is only half the
        battle. Effective communication, problem-solving, and team collaboration
        are what truly bring ambitious projects to life.
      </p>
    </div>

    <!-- Radar Chart -->
    <div class="relative reveal" style="transition-delay: 200ms;">
      <!-- Subtle background glow -->
      <div
        class="absolute inset-0 bg-accent/5 dark:bg-accent/10 rounded-full blur-3xl -z-10"
      >
      </div>

      <div
        class="bg-white/50 dark:bg-slate-900/50 backdrop-blur-xl border border-gray-200/50 dark:border-gray-800/50 p-4 sm:p-6 md:p-10 rounded-[2.5rem] shadow-xl shadow-accent/5"
      >
        <div class="relative w-full aspect-square max-w-md mx-auto">
          <canvas id="skills-radar-chart"></canvas>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const initRadarChart = async () => {
    const canvas = document.getElementById(
      "skills-radar-chart",
    ) as HTMLCanvasElement;
    if (!canvas) return;

    // Destroy existing chart instance to prevent duplicates during Astro page transitions
    if (window.skillsChartInstance) {
      window.skillsChartInstance.destroy();
    }

    const isDark = document.documentElement.classList.contains("dark");

    // Theme colors
    const textColor = isDark ? "#94a3b8" : "#64748b"; // slate-400 or slate-500
    const gridColor = isDark
      ? "rgba(148, 163, 184, 0.1)"
      : "rgba(100, 116, 139, 0.1)";
    const angleLineColor = isDark
      ? "rgba(148, 163, 184, 0.2)"
      : "rgba(100, 116, 139, 0.2)";

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Dynamically import Chart.js only when needed to code-split the application
    const { default: Chart } = await import("chart.js/auto");

    // We use a single dataset that highlights the "shape" of the developer.
    // 6 Technical skills, 6 Soft skills around the 12 axes.
    window.skillsChartInstance = new Chart(ctx, {
      type: "radar",
      data: {
        labels: [
          ["System", "Architecture"],
          ["Frontend", "Engineering"],
          ["Backend", "& APIs"],
          ["Performance", "Optimization"],
          ["Database", "Modeling"],
          ["DevOps &", "Deployment"],
          ["Problem", "Solving"],
          "Communication",
          "Adaptability",
          ["Team", "Collaboration"],
          ["Attention", "to Detail"],
          ["Critical", "Thinking"],
        ],
        datasets: [
          {
            label: "Skill Proficiency",
            data: [85, 95, 92, 80, 85, 72, 95, 90, 85, 90, 93, 85],
            backgroundColor: "rgba(192, 132, 252, 0.4)", // Accent color with opacity
            borderColor: "rgba(192, 132, 252, 1)",
            pointBackgroundColor: "rgba(192, 132, 252, 1)",
            pointBorderColor: "#fff",
            pointHoverBackgroundColor: "#fff",
            pointHoverBorderColor: "rgba(192, 132, 252, 1)",
            borderWidth: 2,
            tension: 0.3,
          },
        ],
      },
      options: {
        layout: {
          padding: 20,
        },
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: {
            display: false, // Hide the legend for a cleaner, minimalist look
          },
          tooltip: {
            backgroundColor: isDark
              ? "rgba(15, 23, 42, 0.9)"
              : "rgba(255, 255, 255, 0.9)",
            titleColor: isDark ? "#f8fafc" : "#0f172a",
            bodyColor: isDark ? "#cbd5e1" : "#334155",
            borderColor: isDark ? "rgba(255,255,255,0.1)" : "rgba(0,0,0,0.1)",
            borderWidth: 1,
            padding: 12,
            boxPadding: 6,
            usePointStyle: true,
            titleFont: {
              size: 14,
              family: "'Inter', sans-serif",
              weight: "bold",
            },
            bodyFont: {
              size: 12,
              family: "'Inter', sans-serif",
            },
            callbacks: {
              label: function (context) {
                return ` ${context.raw}%`;
              },
            },
          },
        },
        scales: {
          r: {
            angleLines: {
              color: angleLineColor,
              lineWidth: 1,
            },
            grid: {
              color: gridColor,
              circular: true,
            },
            pointLabels: {
              color: textColor,
              font: {
                family: "'Inter', sans-serif",
                size: 11,
                weight: "500",
              },
            },
            ticks: {
              display: false, // Hide the numbers (0, 20, 40, etc) to keep it clean
              stepSize: 20,
            },
          },
        },
        animation: {
          duration: 2000,
          easing: "easeOutQuart",
        },
      },
    });
  };

  // Setup observer to trigger animation when scrolled into view
  const setupChartReveal = () => {
    const canvas = document.getElementById(
      "skills-radar-chart",
    ) as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;

    // Reset chart container before revealing so it pops in
    canvas.style.opacity = "0";

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            canvas.style.transition = "opacity 1s ease";
            canvas.style.opacity = "1";
            canvas.dataset.initialized = "true";
            initRadarChart();
            observer.unobserve(canvas);
          }
        });
      },
      { threshold: 0.2 },
    );

    observer.observe(canvas);
  };

  // Listen to dark mode toggles to redraw chart with correct colors
  const setupThemeListener = () => {
    if (window.themeObserver) {
      window.themeObserver.disconnect();
    }

    // Keep track of the current theme to avoid redundant updates
    let wasDark = document.documentElement.classList.contains("dark");

    window.themeObserver = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === "class") {
          const isDark = document.documentElement.classList.contains("dark");

          // Only redraw if the 'dark' class actually changed
          if (isDark !== wasDark && window.skillsChartInstance) {
            wasDark = isDark;

            // Update colors dynamically instead of recreating the chart
            const textColor = isDark ? "#94a3b8" : "#64748b";
            const gridColor = isDark
              ? "rgba(148, 163, 184, 0.1)"
              : "rgba(100, 116, 139, 0.1)";
            const angleLineColor = isDark
              ? "rgba(148, 163, 184, 0.2)"
              : "rgba(100, 116, 139, 0.2)";
            const tooltipBg = isDark
              ? "rgba(15, 23, 42, 0.9)"
              : "rgba(255, 255, 255, 0.9)";
            const tooltipTitle = isDark ? "#f8fafc" : "#0f172a";
            const tooltipBody = isDark ? "#cbd5e1" : "#334155";
            const tooltipBorder = isDark
              ? "rgba(255,255,255,0.1)"
              : "rgba(0,0,0,0.1)";

            const options = window.skillsChartInstance.options;

            // Update Scales
            options.scales.r.angleLines.color = angleLineColor;
            options.scales.r.grid.color = gridColor;
            options.scales.r.pointLabels.color = textColor;

            // Update Tooltips
            options.plugins.tooltip.backgroundColor = tooltipBg;
            options.plugins.tooltip.titleColor = tooltipTitle;
            options.plugins.tooltip.bodyColor = tooltipBody;
            options.plugins.tooltip.borderColor = tooltipBorder;

            // Apply updates without animation
            window.skillsChartInstance.update("none");
          }
        }
      });
    });
    window.themeObserver.observe(document.documentElement, {
      attributes: true,
    });
  };

  // Run on initial load
  setupChartReveal();
  setupThemeListener();
</script>
