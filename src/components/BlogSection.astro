---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
      <!-- Latest Writing Section -->
      <section
        class="py-32 px-6 max-w-6xl mx-auto border-t border-gray-100 dark:border-gray-800"
      >
        <div
          class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
        >
          <div class="reveal">
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
              Latest Writing
            </h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400 max-w-xl text-lg">
              Thoughts on software engineering, design, and building products.
            </p>
          </div>
          <div class="reveal flex-shrink-0" style="transition-delay: 100ms">
            <a
              href="/blog"
              class="inline-flex items-center text-accent hover:text-accent-hover font-medium transition-colors group"
            >
              View all posts
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="ml-2 transition-transform group-hover:translate-x-1"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                  points="12 5 19 12 12 19"></polyline></svg
              >
            </a>
          </div>
        </div>

        <div class="reveal w-full relative overflow-hidden rounded-3xl bg-slate-50 dark:bg-slate-900/50 border border-gray-100 dark:border-gray-800 flex flex-col items-center justify-center py-24 px-6 text-center">
          <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
          <div class="relative z-10 max-w-lg mx-auto">
            <div class="inline-flex items-center justify-center p-3 bg-accent/10 rounded-2xl mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
              Writing in progress
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
              I'm currently wrestling with my keyboard to bring you spicy takes, late-night debugging epiphanies, and thoughts on making the web a cooler place. The first batch of articles is brewing!
            </p>
            <div class="flex items-center justify-center mt-6 gap-3 w-full opacity-80">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent to-accent/60"></div>
              <span class="text-[9px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-[0.25em] animate-pulse whitespace-nowrap">Publishing soon</span>
              <div class="h-px flex-1 bg-gradient-to-l from-transparent to-accent/60"></div>
            </div>
          </div>
        </div>
      </section>