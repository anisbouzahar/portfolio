---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404: Not Found | ${SITE_TITLE}`} description="Oops! This page could not be found." />
	</head>
	<body class="flex flex-col min-h-screen relative bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-50 transition-colors duration-300 antialiased selection:bg-accent selection:text-white">
		<canvas id="canvas-404" class="fixed inset-0 w-full h-full -z-10 opacity-60"></canvas>
		<Header />
		<main class="flex-grow flex items-center justify-center px-4 py-10 pt-32 mx-auto md:py-16 md:pt-40 max-w-2xl w-full relative z-10">
			<div class="text-center space-y-6 animate-fade-in-up w-full">
				<h1 class="text-8xl md:text-9xl font-extrabold tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-accent via-purple-500 to-accent bg-[length:200%_auto] animate-gradient">
					404
				</h1>
				<div class="space-y-3">
					<h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 dark:text-white">
						Lost in space?
					</h2>
					<p class="text-base md:text-lg leading-relaxed text-gray-600 dark:text-gray-400 max-w-md mx-auto">
						The page you're looking for doesn't exist, has been moved, or was abducted by aliens.
					</p>
				</div>
				
				<div class="pt-8">
					<a
						href="/"
						class="inline-flex items-center justify-center h-12 px-8 rounded-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-medium hover:bg-slate-800 dark:hover:bg-gray-100 transition-all duration-300 shadow-sm gap-2 group"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="transition-transform group-hover:-translate-x-1"
						>
							<line x1="19" y1="12" x2="5" y2="12"></line>
							<polyline points="12 19 5 12 12 5"></polyline>
						</svg>
						Back to Home
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	import { Renderer, Camera, Transform, Program, Mesh, Geometry } from 'ogl';
	const init404Canvas = () => {
		const canvas = document.getElementById('canvas-404');
		if (!canvas) return;

		// Clear previous instances for Astro view transitions
		if (window.custom404Render) {
			cancelAnimationFrame(window.custom404Render);
		}

		let width = window.innerWidth;
		let height = window.innerHeight;

		const isDark = document.documentElement.classList.contains('dark');
		const parseHex = (hex) => [((hex >> 16) & 255) / 255, ((hex >> 8) & 255) / 255, (hex & 255) / 255];
		
		const darkBg = parseHex(0x020617);
		const lightBg = parseHex(0xffffff);
		const darkWire = parseHex(0xc084fc);
		const lightWire = parseHex(0x000000);

		const currentBg = isDark ? darkBg : lightBg;

		const renderer = new Renderer({ canvas, antialias: true, dpr: Math.min(window.devicePixelRatio, 2) });
		const gl = renderer.gl;
		gl.clearColor(currentBg[0], currentBg[1], currentBg[2], 1);
		renderer.setSize(width, height);
		window.custom404Renderer = renderer;

		const scene = new Transform();
		const camera = new Camera(gl, { fov: 60, aspect: width / height });
		camera.position.set(0, 0, 30);

		// --- ASTEROID FIELD (Icosahedron) ---
		const t = (1 + Math.sqrt(5)) / 2;
		const vertices = [
			-1,  t,  0,    1,  t,  0,   -1, -t,  0,    1, -t,  0,
			 0, -1,  t,    0,  1,  t,    0, -1, -t,    0,  1, -t,
			 t,  0, -1,    t,  0,  1,   -t,  0, -1,   -t,  0,  1
		];
		const indices = [
			0, 11, 5,   0, 5, 1,    0, 1, 7,    0, 7, 10,   0, 10, 11,
			1, 5, 9,    5, 11, 4,   11, 10, 2,  10, 7, 6,   7, 1, 8,
			3, 9, 4,    3, 4, 2,    3, 2, 6,    3, 6, 8,    3, 8, 9,
			4, 9, 5,    2, 4, 11,   6, 2, 10,   8, 6, 7,    9, 8, 1
		];
		for(let i=0; i<vertices.length; i++) vertices[i] *= 1.5;
		
		const wireIndices = [];
		for(let i=0; i<indices.length; i+=3) {
			wireIndices.push(indices[i], indices[i+1], indices[i+1], indices[i+2], indices[i+2], indices[i]);
		}

		const geometry = new Geometry(gl, {
			position: { size: 3, data: new Float32Array(vertices) },
			index: { data: new Uint16Array(wireIndices) }
		});

		const vertex = `
			attribute vec3 position;
			uniform mat4 modelViewMatrix;
			uniform mat4 projectionMatrix;
			void main() {
				gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
			}
		`;

		const fragment = `
			precision highp float;
			uniform vec3 uColor;
			uniform vec3 uFogColor;
			uniform float uFogDensity;
			
			void main() {
				float depth = gl_FragCoord.z / gl_FragCoord.w;
				float fogFactor = exp2(-uFogDensity * uFogDensity * depth * depth * 1.442695);
				fogFactor = clamp(fogFactor, 0.0, 1.0);
				
				vec4 color = vec4(uColor, 0.3);
				vec4 fogColor = vec4(uFogColor, 1.0);
				
				gl_FragColor = mix(fogColor, color, fogFactor);
			}
		`;

		const program = new Program(gl, {
			vertex,
			fragment,
			uniforms: {
				uColor: { value: isDark ? darkWire : lightWire },
				uFogColor: { value: currentBg },
				uFogDensity: { value: 0.02 }
			},
			transparent: true
		});

		const count = 150;
		const asteroids = [];

		for (let i = 0; i < count; i++) {
			const mesh = new Mesh(gl, { geometry, program, mode: gl.LINES });
			mesh.setParent(scene);
			
			const x = (Math.random() - 0.5) * 100;
			const y = (Math.random() - 0.5) * 100;
			const z = (Math.random() - 0.5) * 100 - 20; // Bias towards the back
			
			const rx = Math.random() * Math.PI;
			const ry = Math.random() * Math.PI;
			const rz = Math.random() * Math.PI;
			
			const scale = Math.random() * 1.5 + 0.5;

			const speedX = (Math.random() - 0.5) * 0.02;
			const speedY = (Math.random() - 0.5) * 0.02;
			const speedZ = Math.random() * 0.08 + 0.02; // Always drifting towards camera
			const rotSpeedX = (Math.random() - 0.5) * 0.02;
			const rotSpeedY = (Math.random() - 0.5) * 0.02;

			mesh.position.set(x, y, z);
			mesh.rotation.set(rx, ry, rz);
			mesh.scale.set(scale, scale, scale);

			asteroids.push({ mesh, speedX, speedY, speedZ, rotSpeedX, rotSpeedY });
		}

		// --- PARALLAX MOUSE TRACKING ---
		let mouseX = 0;
		let mouseY = 0;
		let targetX = 0;
		let targetY = 0;
		const windowHalfX = width / 2;
		const windowHalfY = height / 2;

		const onDocumentMouseMove = (event) => {
			mouseX = (event.clientX - windowHalfX) * 0.05;
			mouseY = (event.clientY - windowHalfY) * 0.05;
		};
		document.addEventListener('mousemove', onDocumentMouseMove);

		// --- ANIMATION LOOP ---
		const animate = () => {
			// Update asteroid positions
			for (let i = 0; i < count; i++) {
				const data = asteroids[i];
				const m = data.mesh;
				
				// Drift
				m.position.x += data.speedX;
				m.position.y += data.speedY;
				m.position.z += data.speedZ;
				
				// Tumble
				m.rotation.x += data.rotSpeedX;
				m.rotation.y += data.rotSpeedY;

				// Reset if it flies past the camera
				if (m.position.z > 35) {
					m.position.z = -60;
					m.position.x = (Math.random() - 0.5) * 100;
					m.position.y = (Math.random() - 0.5) * 100;
				}
			}

			// Smooth mouse parallax
			targetX = mouseX * 0.5;
			targetY = mouseY * 0.5;
			camera.position.x += (targetX - camera.position.x) * 0.05;
			camera.position.y += (5 - targetY - camera.position.y) * 0.05;
			camera.lookAt([0, 0, 0]);

			renderer.render({ scene, camera });
			window.custom404Render = requestAnimationFrame(animate);
		};

		animate();

		// --- DYNAMIC THEME UPDATES ---
		const observer = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (mutation.attributeName === 'class') {
					const currentlyDark = document.documentElement.classList.contains('dark');
					const bg = currentlyDark ? darkBg : lightBg;
					program.uniforms.uColor.value = currentlyDark ? darkWire : lightWire;
					program.uniforms.uFogColor.value = bg;
					gl.clearColor(bg[0], bg[1], bg[2], 1);
				}
			});
		});
		observer.observe(document.documentElement, { attributes: true });

		// Cleanup observer on view transition
		document.addEventListener('astro:before-swap', () => observer.disconnect(), { once: true });

		// Handle resize
		window.addEventListener('resize', () => {
			width = window.innerWidth;
			height = window.innerHeight;
			camera.perspective({ aspect: width / height });
			renderer.setSize(width, height);
		});
	};

	// Run on initial load and after Astro view transitions
	init404Canvas();
	document.addEventListener("astro:page-load", init404Canvas);
</script>

<style>
	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	
	.animate-gradient {
		animation: gradient 6s linear infinite;
	}
</style>
